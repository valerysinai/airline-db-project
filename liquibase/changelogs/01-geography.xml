<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="geography-001" author="aprendiz" context="ddl">
        <sql>
            CREATE EXTENSION IF NOT EXISTS pgcrypto;
        </sql>
    </changeSet>

    <changeSet id="geography-002" author="aprendiz" context="ddl">
        <createTable tableName="time_zone">
            <column name="time_zone_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>

            <column name="time_zone_name" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="utc_offset_minutes" type="integer">
                <constraints nullable="false"/>
            </column>

            <!-- demás columnas del dominio -->
        </createTable>
    </changeSet>

    <!-- Un changeSet por cada tabla del dominio -->

</databaseChangeLog>